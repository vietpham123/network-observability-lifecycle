# =============================================================================
# .env.example  —  copy to .env (git-ignored) and fill in the CHANGE-ME values.
#   Load with:  set -a && source .env && set +a
# Nothing secret is committed. The real .env stays local.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) DYNATRACE TENANT  (you have this)
# -----------------------------------------------------------------------------
# Your environment id is the subdomain of your tenant URL, e.g. abc12345 in
#   https://abc12345.live.dynatrace.com
# For a Gen3/Platform tenant it may look like https://abc12345.apps.dynatrace.com
DT_ENV_ID=CHANGE-ME                         # e.g. abc12345
DYNATRACE_ENV_URL=https://CHANGE-ME.live.dynatrace.com

# The SAME token value is consumed under two variable names by different tools:
#   - DT_API_TOKEN         -> Monaco  + Ansible dynatrace_sync
#   - DYNATRACE_API_TOKEN  -> Terraform dynatrace provider
# Create it in Dynatrace: Settings > Access tokens > Generate new token.
# Required scopes (superset across Monaco + Terraform + Ansible):
#   events.ingest        (change events)
#   logs.ingest          (compliance logs)
#   settings.read
#   settings.write       (mgmt zones, metric events, log processing, auto-tags, retention)
#   entities.read
#   ReadConfig           (classic config API — dashboards)
#   WriteConfig          (classic config API — dashboards)
DT_API_TOKEN=dt0c01.CHANGE-ME
DYNATRACE_API_TOKEN=dt0c01.CHANGE-ME        # <- paste the SAME token value here

# -----------------------------------------------------------------------------
# 2) AZURE  (auth handled by `az login` — no secrets needed here)
# -----------------------------------------------------------------------------
# These just parameterize the Gate-2 lab VMs that act as Ansible "devices".
# Confirm the subscription with:  az account show
AZURE_SUBSCRIPTION_ID=7a91e8b3-ee09-4906-91a2-f357b77a61fd   # Sales-Engineering/NORAM (auto-detected)
AZURE_LOCATION=eastus                       # region for the lab
AZURE_RESOURCE_GROUP=rg-netobs-lab          # created/torn down for the test
LAB_VM_COUNT=3                              # stand-in devices (core switch / edge router / firewall)
LAB_VM_SIZE=Standard_B1s                    # cheapest that works; bump for containerlab
LAB_ADMIN_USER=netobs
LAB_SSH_PUBKEY_PATH="~/.ssh/id_ed25519.pub" # public key injected into the VMs

# -----------------------------------------------------------------------------
# 3) RUN OPTIONS
# -----------------------------------------------------------------------------
CAAC_TOOL=terraform                         # terraform | monaco  (which CaC engine to deploy with)
REPO_ROOT="/Users/viet.pham/Downloads/network repo/network-observability-lifecycle"
